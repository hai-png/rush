// Addis Ride — clean reimplementation. Single source of truth.
// SQLite backend; all invariants enforced in app code (no DB triggers).
// Money is integer cents (1 ETB = 100 cents) to avoid Decimal/float issues.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  phone           String   @unique
  email           String?
  passwordHash    String
  name            String
  role            String   @default("rider") // rider | contractor | corporate_admin | platform_admin
  phoneVerified   Boolean  @default(false)
  isActive        Boolean  @default(true)
  deletedAt       DateTime?
  tokenVersion    Int      @default(0) // bump to invalidate all sessions
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  tosVersion      String?
  // P1-8 / API-030: account lockout after failed login attempts.
  failedLoginAttempts Int  @default(0)
  lockedUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  riderProfile       RiderProfile?
  contractorProfile  ContractorProfile?
  corporate          Corporate?           @relation("CorporateAdmin")
  corporateMembers   CorporateMember[]
  sessions           Session[]
  subscriptions      Subscription[]
  payments           Payment[]
  rides              Ride[]
  seatReleases       SeatRelease[]        @relation("SeatReleaseSeller")
  seatClaims         SeatClaim[]          @relation("SeatClaimBuyer")
  tickets            SupportTicket[]
  ticketMessages     TicketMessage[]
  notifications      Notification[]
  auditLogsActor     AuditLog[]           @relation("AuditActor")
  auditLogsVerifier  ContractorProfile[]  @relation("VerifiedBy")
  tosAcceptances     TosAcceptance[]
  drivesTrips        Trip[]               @relation("TripDriver")
  drivesShuttles     Shuttle[]
  assignmentsAsContractor RouteAssignment[] @relation("AssignmentContractor")
  assignmentsAsAssigner   RouteAssignment[] @relation("AssignmentAssigner")
  idempotencyRecords IdempotencyRecord[]
  otpCodes           OtpCode[]
  uploadedFiles      UploadedFile[]       @relation("FileUploader")
  corporateInvites   CorporateInvite[]    @relation("InviteCreator")
  mandates           Mandate[]
  twoFactorBackupCodes TwoFactorBackupCode[]

  @@index([isActive, deletedAt])
  @@index([role, isActive])           // P1-15: admin lookups (notify all admins)
}

model RiderProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeArea  String
  workArea  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber       String   @unique
  experienceYears     Int      @default(0)
  rating              Float    @default(5.0)
  verificationStatus  String   @default("unverified") // unverified | pending | verified | rejected
  verificationReason  String?
  verifiedById        String?
  verifiedBy          User?    @relation("VerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  documents           ContractorDocument[]

  @@index([verificationStatus])    // P1: admin pending-contractors query
}

model Corporate {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  contactEmail        String
  contactPhone        String
  subsidyPercent      Int      @default(50)
  monthlySeatAllowance Int     @default(20)
  adminUserId         String   @unique
  adminUser           User     @relation("CorporateAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  isActive            Boolean  @default(true)
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  members      CorporateMember[]
  subscriptions Subscription[]
  invites      CorporateInvite[]
}

model CorporateMember {
  id                  String   @id @default(cuid())
  corporateId         String
  corporate           Corporate @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId          String
  approvalStatus      String   @default("pending") // pending | approved | rejected
  ridesUsedThisMonth  Int      @default(0)
  lastResetAt         DateTime @default(now())
  isActive            Boolean  @default(true)
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([corporateId, userId])
  @@index([userId])
  @@index([lastResetAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([userId, revokedAt, expiresAt])   // P1: revokeAllSessionsForUser + GET /auth/sessions
}

model OtpCode {
  id          String   @id @default(cuid())
  phone       String
  purpose     String   // signup_verification | password_reset | phone_change
  codeHash    String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  expiresAt   DateTime
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phone, purpose])
}

model TosAcceptance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version    String
  ipAddress  String?
  userAgent  String?
  acceptedAt DateTime @default(now())

  @@index([userId])
}

// ─── Catalog (plans, routes, shuttles, trips) ────────────────────────────────

model SubscriptionPlan {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String
  priceCents     Int
  currency       String   @default("ETB")
  ridesIncluded  Int      // -1 = unlimited
  durationDays   Int
  isTrial        Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions  Subscription[]

}

model Route {
  id           String   @id @default(cuid())
  origin       String
  destination  String
  distanceKm   Float
  durationMin  Int
  fareCents    Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pickups          PickupLocation[]
  assignments     RouteAssignment[]
  trips           Trip[]  // legacy — keep for backward compat

}

// Predefined pickup locations along a route. Riders choose one when booking.
// e.g. Route "Bole → Merkato" might have pickups at: Bole Friendship, Bole
// Rwanda, CMC, Megenagna. Each has a name + lat/lng + estimated pickup time.
model PickupLocation {
  id          String   @id @default(cuid())
  routeId     String
  route       Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Bole Friendship"
  lat         Float?
  lng         Float?
  estimatedPickupTime String  // e.g. "07:15" — HH:MM relative to departure
  sortOrder   Int      @default(0)  // order along the route
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  rides       Ride[]

  @@index([routeId])
}

model Shuttle {
  id            String   @id @default(cuid())
  contractorId  String
  contractor    User     @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  plate         String   @unique
  model         String
  vehicleType   String   // coaster | minibus | van | sedan
  capacity      Int
  year          Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips         Trip[]
  assignments   RouteAssignment[]

  @@index([contractorId])            // P1: contractor dashboard + GET_my_shuttles
  @@index([contractorId, isActive])
}

model Trip {
  id            String   @id @default(cuid())
  routeId       String
  route         Route    @relation(fields: [routeId], references: [id], onDelete: Restrict)
  shuttleId     String
  shuttle       Shuttle  @relation(fields: [shuttleId], references: [id], onDelete: Restrict)
  driverId      String?
  driver        User?    @relation("TripDriver", fields: [driverId], references: [id], onDelete: SetNull)
  departureAt   DateTime
  seatsBooked   Int      @default(0)
  status        String   @default("scheduled") // scheduled | in_transit | completed | cancelled
  window        String   // morning | evening
  // Link to the monthly assignment this trip was generated from.
  assignmentId  String?
  assignment    RouteAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rides         Ride[]
  seatReleases  SeatRelease[]

  @@index([routeId, departureAt])
  @@index([shuttleId, departureAt])
  @@index([assignmentId])
  @@index([driverId, departureAt])   // P1: contractor dashboard + recomputeContractorRating
  @@index([status, departureAt])     // P1: GET /trips catalog + expireStale
  @@unique([routeId, departureAt, window])  // P0: prevent duplicate trips from scheduler re-runs
}

// ─── Route Assignments (monthly commitments) ────────────────────────────────
// A contractor commits to serving a route for a month with a specific shuttle
// and a recurring schedule (e.g. Mon-Fri mornings + evenings). Admin assigns
// routes to contractors; riders subscribe to assignments.
//
// This replaces the old "Trip per day" model. Individual daily trips are
// generated from the assignment's schedule pattern (Mon-Fri → 20-22 trips/month).

model RouteAssignment {
  id            String   @id @default(cuid())
  routeId       String
  route         Route    @relation(fields: [routeId], references: [id], onDelete: Restrict)
  contractorId  String   // the driver/contractor assigned to this route
  contractor    User     @relation("AssignmentContractor", fields: [contractorId], references: [id], onDelete: Cascade)
  shuttleId     String
  shuttle       Shuttle  @relation(fields: [shuttleId], references: [id], onDelete: Restrict)

  // Monthly period — the contractor commits to this route for this month.
  // Format: monthStart is the first day of the month at 00:00.
  monthStart    DateTime
  monthEnd      DateTime

  // Schedule pattern: which days of week + which windows.
  // Stored as JSON: { "days": ["mon","tue","wed","thu","fri"], "windows": ["morning","evening"] }
  // The scheduler generates individual Trip rows from this pattern.
  schedulePattern String  // JSON

  // Status: admin assigns → contractor accepts → active → completed
  status        String   @default("assigned") // assigned | accepted | active | completed | cancelled

  // Capacity tracking
  maxSeats      Int      @default(0)  // copied from shuttle.capacity for quick reference
  seatsBooked   Int      @default(0)

  assignedById  String?  // admin who assigned
  assignedBy    User?    @relation("AssignmentAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  acceptedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips         Trip[]   // generated daily trips
  rides         Ride[]   // rides booked against this assignment

  @@unique([routeId, contractorId, monthStart])  // one assignment per route+contractor+month
  @@index([contractorId, monthStart])
  @@index([routeId, monthStart])
  @@index([status, monthStart])
}

// ─── Subscriptions + payments ────────────────────────────────────────────────

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  corporateId  String?
  corporate    Corporate? @relation(fields: [corporateId], references: [id], onDelete: SetNull)
  status       String   @default("pending_payment") // pending_payment | active | expired | cancelled
  startDate    DateTime
  endDate      DateTime
  ridesUsed    Int      @default(0)
  cancelledAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments     Payment[]
  rides        Ride[]
  tickets      SupportTicket[]

  @@index([userId, status])
  @@index([corporateId])
  @@index([status, endDate])            // P1: expireStale scheduler job
}

model Payment {
  id               String   @id @default(cuid())
  reference        String   @unique // merchOrderId for Telebirr
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  seatClaimId      String?
  method           String   // telebirr | cbe
  amountCents      Int
  status           String   @default("pending") // pending | completed | failed | refunded | partially_refunded
  refundAmountCents Int    @default(0)
  refundedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  refundRetries       RefundRetry[]
  seatClaim           SeatClaim?   @relation("SeatClaimPayment")
  tickets             SupportTicket[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([seatClaimId])
  @@index([status])
}

model RefundRetry {
  id              String   @id @default(cuid())
  paymentId       String
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  merchOrderId    String
  refundRequestNo String   @unique
  amountCents     Int
  reason          String
  status          String   @default("pending") // pending | processing | succeeded | failed | permanent_failure
  attempts        Int      @default(0)
  maxAttempts     Int      @default(5)
  nextAttemptAt   DateTime @default(now())
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([paymentId])
  @@index([status, nextAttemptAt])
}

// Telebirr webhook dedup — done right the first time.
// PK is (merchOrderId, outRequestNo) per Telebirr's own dedup semantics.
// No received_at in the PK (that was the bug that took 3 migrations to fix).
model TelebirrNotifyEvent {
  // Pure log table — no FK to Payment so Payment deletion can't ripple here.
  merchOrderId    String
  outRequestNo    String
  tradeStatus     String
  totalAmount     String?
  rawPayload      String   // JSON
  receivedAt      DateTime @default(now())

  @@id([merchOrderId, outRequestNo])
  @@index([merchOrderId, receivedAt])
}

// ─── Marketplace (seat release / claim) ──────────────────────────────────────

model SeatRelease {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("SeatReleaseSeller", fields: [userId], references: [id], onDelete: Cascade)
  tripId       String
  trip         Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  window       String   // morning | evening
  status       String   @default("open") // open | claimed | expired | cancelled
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  claims       SeatClaim[]

  @@index([status, expiresAt])
  @@index([tripId])
}

model SeatClaim {
  id            String   @id @default(cuid())
  seatReleaseId String
  seatRelease   SeatRelease @relation(fields: [seatReleaseId], references: [id], onDelete: Cascade)
  claimantUserId String
  claimant      User     @relation("SeatClaimBuyer", fields: [claimantUserId], references: [id], onDelete: Cascade)
  paymentId     String   @unique
  payment       Payment  @relation("SeatClaimPayment", fields: [paymentId], references: [id], onDelete: Restrict)
  status        String   @default("confirmed") // confirmed | used | no_show | refunded
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rides         Ride[]

  @@index([claimantUserId])
  @@index([seatReleaseId])
}

// ─── Operations (rides) ──────────────────────────────────────────────────────

model Ride {
  id              String   @id @default(cuid())
  tripId          String
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  seatClaimId     String?
  seatClaim       SeatClaim? @relation(fields: [seatClaimId], references: [id], onDelete: SetNull)
  // The pickup location the rider chose for this ride.
  pickupLocationId String?
  pickupLocation   PickupLocation? @relation(fields: [pickupLocationId], references: [id], onDelete: SetNull)
  // Link to the monthly assignment (for reporting — which assignment generated this ride).
  assignmentId   String?
  assignment     RouteAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  status          String   @default("booked") // booked | boarded | completed | no_show | cancelled | released
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([tripId])
  @@index([subscriptionId])
  @@index([seatClaimId])
  @@index([pickupLocationId])
  @@index([assignmentId])
  @@index([tripId, userId, status])    // P1: marketplace release/claim + double-book check
}

// ─── Support ─────────────────────────────────────────────────────────────────

model SupportTicket {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         String
  category        String   @default("general") // general | billing | route | shuttle | account | corporate | other
  priority        String   @default("normal") // low | normal | high | urgent
  status          String   @default("open") // open | in_progress | resolved | closed
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentId       String?
  payment         Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  fileId     String?  // optional attachment
  file       UploadedFile? @relation("TicketMessageFile", fields: [fileId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([ticketId, createdAt])
}

model FaqArticle {
  id         String   @id @default(cuid())
  category   String   // general | billing | route | shuttle | account | corporate | other
  question   String
  answer     String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Holidays (skip trip generation) ─────────────────────────────────────────
// P2 / BIZ-054: admin-managed list of Ethiopian public holidays. The trip
// generator skips these dates so riders don't book rides on holidays where
// the shuttle won't run.
model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique  // the calendar date (time component ignored)
  name      String             // e.g. "Ethiopian New Year"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Engagement + audit + outbox ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // payment_received | payment_failed | refund_completed | refund_failed | seat_claimed | seat_released | seat_release_expired | subscription_activated | subscription_expiring | subscription_expired | subscription_cancelled | trip_cancelled | trip_departing | support_reply | support_resolved | corporate_member_added | corporate_member_removed | corporate_reset | general
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, type, createdAt])    // P1: scheduler dedup for expiry warnings
}

model AuditLog {
  id         String   @id @default(cuid())
  seq        Int      @unique @default(0)  // P1: monotonic sequence for hash-chain ordering (replaces createdAt ordering)
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  before     String?  // JSON
  after      String?  // JSON
  ipAddress  String?
  userAgent  String?
  prevHash   String?
  hash       String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([seq])        // P1: verifyAuditChain pagination by sequence
}

model OutboxEvent {
  id            String   @id @default(cuid())
  channel       String   // notification | sms | email | push
  payload       String   // JSON
  status        String   @default("pending") // pending | processing | delivered | failed | dead
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)
  nextAttemptAt DateTime @default(now())
  lastError     String?
  lockedAt      DateTime?
  lockedBy      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([channel, status])
}

model IdempotencyRecord {
  key              String   @id
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  method           String
  path             String
  requestBodyHash  String
  responseStatus   Int      @default(0) // 0 = processing
  responseBody     String   @default("{}") // JSON
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── File uploads ────────────────────────────────────────────────────────────
// Generic uploaded file record. The actual bytes live on disk (UPLOAD_DIR) or
// S3 in production; this table is the metadata index. Used by contractor
// documents (registration/insurance/inspection), ticket-message attachments,
// and any future upload needs.

// Key-value admin settings (single source of truth — do NOT stuff these into
// the audit log, the previous implementation only kept the latest key).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UploadedFile {
  id              String   @id @default(cuid())
  uploaderId      String
  uploader        User     @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  originalFilename String
  storageKey      String   @unique // path under UPLOAD_DIR (e.g. contractor-docs/<id>.pdf)
  mimeType        String
  sizeBytes       Int
  checksumSha256  String
  // Document scan status — for contractor docs, a real AV scan would set this.
  // 'pending' on upload, 'clean' after scan, 'infected' if a threat is found.
  scanStatus      String   @default("pending") // pending | clean | infected | error
  createdAt       DateTime @default(now())

  contractorDocuments ContractorDocument[]
  ticketMessages      TicketMessage[]    @relation("TicketMessageFile")

  @@index([uploaderId])
  @@index([scanStatus])
}

// Contractor onboarding documents: registration (business license), insurance,
// inspection (vehicle safety). Required before verification_status can move
// from 'unverified' to 'verified'.
model ContractorDocument {
  id              String   @id @default(cuid())
  contractorId    String   // references ContractorProfile.id
  contractor      ContractorProfile @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  type            String   // registration | insurance | inspection
  fileId          String
  file            UploadedFile @relation(fields: [fileId], references: [id], onDelete: Restrict)
  uploadedAt      DateTime @default(now())

  @@unique([contractorId, type]) // one of each type per contractor
  @@index([contractorId])
}

// ─── Corporate invites ──────────────────────────────────────────────────────
// A corporate admin generates an invite code; members use it during signup
// to associate themselves with the corporate. The admin then approves/rejects.
model CorporateInvite {
  id          String    @id @default(cuid())
  corporateId String
  corporate   Corporate @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  code        String    @unique
  createdById String
  createdByUser User    @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  note        String?   // free-form, e.g. "For Engineering team"
  maxUses     Int       @default(50)
  usesCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([corporateId])
}

// ─── Telebirr Mandates (recurring billing authorization) ─────────────────────
// P1 / BIZ-043: persisted mandate records so we can track which user signed
// which mandate, and use it for recurring disbursement against subscriptions.
model Mandate {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  mctContractNo     String   @unique  // 32-digit numeric, generated via crypto.randomInt
  mandateTemplateId String?
  status            String   @default("pending") // pending | signed | cancelled | expired
  signedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

// ─── 2FA backup codes ────────────────────────────────────────────────────────
// P3-25 / SEC-025: single-use recovery codes for users who lose their TOTP
// device. 10 codes generated at 2FA enable time, stored bcrypt-hashed.
model TwoFactorBackupCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}
