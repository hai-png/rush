# Multi-stage build for the web app.
#
# The previous Dockerfile was a single stage that ran as root, copied the
# entire repo (including .git, node_modules, docs, scripts) into the image,
# and ran `bun install` after `COPY . .` (invalidating the install layer
# on every source change). Now:
#   - Multi-stage: deps stage caches bun install, builder stage produces
#     the .next output, runner stage is minimal.
#   - Non-root user: the web process runs as uid 10001 ('nextjs').
#   - Healthcheck wired to /api/v1/healthz (FIX INFRA-002: previously
#     /api/v1/health which is admin-gated).
#   - Only the production output is copied — no source, no dev deps.
#   - INFRA-003/INFRA-005: pin to bun 1.3.14-slim (matches packageManager
#     in package.json; bun.lock is in the 1.2+ text format).

FROM oven/bun:1.3.14-slim AS deps
WORKDIR /app
# Copy lockfile + package manifests first so install is cached.
# FIX (INFRA-001): copy bun.lock (committed) — bun.lockb is no longer used.
COPY bun.lock package.json turbo.json tsconfig.base.json ./
COPY apps/web/package.json apps/web/
COPY packages/api/package.json packages/api/
COPY packages/db/package.json packages/db/
COPY packages/shared/package.json packages/shared/
COPY packages/sdk/package.json packages/sdk/
COPY packages/ui/package.json packages/ui/
COPY packages/i18n/package.json packages/i18n/
COPY services/payments/package.json services/payments/
COPY services/sms/package.json services/sms/
RUN bun install --frozen-lockfile

FROM oven/bun:1.3.14-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NODE_ENV=production
RUN bun run --cwd packages/db generate
RUN bun run --filter=web build

FROM oven/bun:1.3.14-slim AS runner
WORKDIR /app
ENV NODE_ENV=production

# Create a non-root user.
RUN addgroup --system --gid 10001 nextjs \
 && adduser --system --uid 10001 --gid 10001 nextjs

# Copy only what's needed to run.
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/.next apps/web/.next
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/public apps/web/public
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/package.json apps/web/package.json
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/next.config.ts apps/web/next.config.ts
COPY --from=builder --chown=nextjs:nextjs /app/node_modules node_modules
COPY --from=builder --chown=nextjs:nextjs /app/package.json package.json
COPY --from=builder --chown=nextjs:nextjs /app/packages packages
COPY --from=builder --chown=nextjs:nextjs /app/services services
COPY --from=builder --chown=nextjs:nextjs /app/tsconfig.base.json tsconfig.base.json

USER nextjs
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD wget -q --spider http://localhost:3000/api/v1/healthz || exit 1
# FIX (INFRA-002): probe /api/v1/healthz (the unauthenticated liveness probe).
# The previous probe hit /api/v1/health, which is admin-gated, so the
# container reported unhealthy even though the app was serving fine.

CMD ["bun", "run", "--cwd", "apps/web", "start"]
