# Addis Ride — Environment Variable Template
#
# FIX (INFRA-012): docker-compose.yml referenced `env_file: ../.env` but no
# committed template existed, so new developers had to reverse-engineer the
# required vars from `packages/shared/src/env.ts` and the various service
# configs. This file is the canonical template; copy to `.env` and fill in
# real values. `.env` itself is gitignored (see .gitignore).
#
# Values shown are the development defaults (matches docker-compose.yml).
# For production, override every secret — see infra/deploy/README.md.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database (Postgres 16) ---
# docker-compose.yml: POSTGRES_PASSWORD=addisride_dev_only_change_me
DATABASE_URL=postgres://addisride:addisride_dev_only_change_me@localhost:5432/addisride

# --- Web (Next.js auth) ---
# 32+ chars, mixed case + digits + symbols. Generate with `openssl rand -base64 48`.
NEXTAUTH_SECRET=replace-with-32-plus-char-strong-secret-value-here
NEXTAUTH_URL=http://localhost:3000

# --- Cron (HTTP-triggered job auth) ---
# 32+ chars, mixed case + digits + symbols. Generate with `openssl rand -base64 48`.
CRON_SECRET=replace-with-different-32-plus-char-strong-secret

# --- Cursor pagination signing ---
# 32+ chars. If unset, falls back to NEXTAUTH_SECRET (not recommended).
CURSOR_SECRET=

# --- Redis (rate limit, OTP locks, cron locks, idempotency dedup) ---
# REDIS_URL is OPTIONAL in dev (the app falls back to InMemoryRedis) but
# MANDATORY in production (see packages/shared/src/env.ts refine).
#
# FIX (INFRA-013): Upstash (managed Redis) exposes Redis over REST + TLS and
# authenticates with a token in the URL's query string or the REDIS_TOKEN env
# var. Self-hosted Redis (docker-compose.yml) uses native Redis AUTH with
# REDIS_PASSWORD. These are NOT interchangeable — pick one mode per
# environment and document it. docker-compose.yml sets REDIS_PASSWORD and
# starts Redis with --requirepass; the app connects via REDIS_URL
# (rediss://...?password=...) or REDIS_TOKEN (Upstash). If you mix modes
# (e.g. self-hosted Redis + REDIS_TOKEN), the auth handshake will fail
# silently — see the note in infra/docker-compose.yml.
REDIS_URL=
REDIS_TOKEN=

# --- Telebirr payment integration ---
# All 6 Telebirr vars must be set together, or all unset, per env.ts refine.
TELEBIRR_ENV=testbed
TELEBIRR_NOTIFY_URL=http://localhost:3000/api/v1/webhooks/telebirr/notify
TELEBIRR_REDIRECT_URL=http://localhost:3000/checkout/complete
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_APP_SECRET=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
TELEBIRR_PRIVATE_KEY=
TELEBIRR_PUBLIC_KEY=

# --- CBE bank transfer (manual reconciliation) ---
CBE_ACCOUNT_NUMBER=
CBE_ACCOUNT_NAME=
CBE_BANK_BRANCH=

# --- Africa's Talking (SMS) ---
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

# --- Expo (push notifications) ---
# Required in production — Expo rate-limits unauthenticated push silently.
EXPO_ACCESS_TOKEN=

# --- VAPID (web push) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Resend (email) ---
RESEND_API_KEY=

# --- S3 / MinIO (object storage) ---
# docker-compose.yml: MINIO_ROOT_USER=addisride, MINIO_ROOT_PASSWORD=addisride_dev_only_change_me_32chars
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=addis-ride-dev
S3_ACCESS_KEY_ID=addisride
S3_SECRET_ACCESS_KEY=addisride_dev_only_change_me_32chars
S3_REGION=us-east-1

# --- bcrypt cost (10-15, default 12) ---
BCRYPT_COST=12

# --- Sentry (error monitoring) ---
# Optional in dev, required in production.
SENTRY_DSN=

# --- DPO contact (Proclamation 1321/2024) ---
DPO_EMAIL=dpo@addisride.et

# --- /metrics password (mandatory in production) ---
METRICS_PASSWORD=

# --- Map tile server (optional) ---
NEXT_PUBLIC_TILE_SERVER_URL=
NEXT_PUBLIC_CARTO_API_KEY=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
