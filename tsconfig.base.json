{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Additional strict flags that catch real bugs:
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@addis/shared": ["packages/shared/src/index.ts"],
      "@addis/shared/*": ["packages/shared/src/*"],
      "@addis/db": ["packages/db/src/index.ts"],
      "@addis/db/*": ["packages/db/src/*"],
      "@addis/api": ["packages/api/src/index.ts"],
      "@addis/api/*": ["packages/api/src/*"],
      "@addis/sdk": ["packages/sdk/src/index.ts"],
      "@addis/ui": ["packages/ui/src/index.ts"],
      "@addis/i18n": ["packages/i18n/src/index.ts"]
    }
  }
}
