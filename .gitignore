# Dependencies
node_modules
.pnp
.pnp.js
# FIX (INFRA-001): bun.lock is the single source of truth for dependency
# resolution and MUST be committed. Previously both `bun.lockb` and
# `bun.lock` were gitignored, so CI/dev/prod resolved different versions
# depending on when each ran `bun install`.

# Build artifacts
.next/
out/
dist/
build/
*.tsbuildinfo
.turbo/
.cache/

# Next.js auto-generated type declarations (regenerated on every dev/build).
next-env.d.ts

# Expo (React Native) build cache and generated native dirs.
.expo/
ios/
android/

# Test artifacts
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files — secrets must NEVER be committed.
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.test

