# .env.example — copy to .env and fill in real values.
#
# All secrets MUST be at least 32 characters with mixed case + digits + symbols.
# The env validator (packages/shared/src/env.ts) rejects placeholder values
# like "changeme", "secret", "password", "dev", "12345678", etc.

# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
# DATABASE_URL — for local dev with docker-compose:
#   postgres://addisride:addisride_dev_only_change_me@localhost:5432/addisride
# For production, use your real Postgres connection string with ssl=require.
DATABASE_URL=postgres://addisride:addisride_dev_only_change_me@localhost:5432/addisride
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-48-min-32-chars
CRON_SECRET=generate-with-openssl-rand-base64-48-min-32-chars

# ── Redis ─────────────────────────────────────────────────────────────────
# Upstash (managed) — REDIS_URL must be https://...upstash.io with a REDIS_TOKEN.
# Self-hosted Redis (e.g. docker-compose) is NOT supported by @upstash/redis
# (it's a REST client). For local dev, either:
#   1. Use Upstash's free tier (recommended), OR
#   2. Set NODE_ENV=development and leave REDIS_URL unset — the in-memory
#      fallback shim (packages/api/infra/redis.ts) will be used. Note: the
#      in-memory shim does NOT survive restarts and is single-process only.
REDIS_URL=
REDIS_TOKEN=

# ── Telebirr ──────────────────────────────────────────────────────────────
# Get these from the Telebirr developer portal.
# TELEBIRR_ENV: 'testbed' for sandbox, 'production' for live.
TELEBIRR_ENV=testbed
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_APP_SECRET=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
TELEBIRR_PRIVATE_KEY=
TELEBIRR_PUBLIC_KEY=
TELEBIRR_NOTIFY_URL=http://localhost:3000/api/v1/webhooks/telebirr/notify
TELEBIRR_REDIRECT_URL=http://localhost:3000/checkout/complete

# ── CBE Birr (manual bank transfer) ───────────────────────────────────────
CBE_ACCOUNT_NUMBER=
CBE_ACCOUNT_NAME=
CBE_BANK_BRANCH=

# ── S3 / MinIO ────────────────────────────────────────────────────────────
# For local dev with docker-compose MinIO:
#   S3_ENDPOINT=http://localhost:9000
#   S3_BUCKET=addisride
#   S3_ACCESS_KEY_ID=addisride
#   S3_SECRET_ACCESS_KEY=addisride_dev_only_change_me_32chars
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=addisride
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=addisride
S3_SECRET_ACCESS_KEY=addisride_dev_only_change_me_32chars

# ── Notifications ─────────────────────────────────────────────────────────
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
EXPO_ACCESS_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
RESEND_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
# METRICS_PASSWORD — required in production (the /metrics endpoint is
# Basic-auth-gated with username 'metrics' and this password). Min 16 chars.
METRICS_PASSWORD=

# ── Map tiles (public, safe for client bundle) ───────────────────────────
NEXT_PUBLIC_TILE_SERVER_URL=
NEXT_PUBLIC_CARTO_API_KEY=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_TELEBIRR_ENV=testbed
# NEXT_PUBLIC_CBE_* — shown on the CBE instructions page.
NEXT_PUBLIC_CBE_ACCOUNT_NUMBER=
NEXT_PUBLIC_CBE_ACCOUNT_NAME=
NEXT_PUBLIC_CBE_BANK_BRANCH=

# ── Optional: trusted proxy CIDRs for X-Forwarded-For ────────────────────
# Comma-separated CIDR list. When set, clientIp() trusts XFF only if the
# immediate connection comes from one of these CIDRs. Leave empty to never
# trust XFF (use the TCP peer address directly).
TRUSTED_PROXIES=

# ── DPO contact ───────────────────────────────────────────────────────────
DPO_EMAIL=dpo@addisride.et
