NODE_ENV=development
DATABASE_URL=file:./db/custom.db
AUTH_SECRET=dev-only-insecure-secret-32-chars-min
CRON_SECRET=dev-only-cron-secret-32-chars
CURRENT_TOS_VERSION=2026-01-01
APP_BASE_URL=http://localhost:3000
TELEBIRR_ENV=mock
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_APP_SECRET=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
TELEBIRR_PRIVATE_KEY=
TELEBIRR_PUBLIC_KEY=
TELEBIRR_NOTIFY_URL=
TELEBIRR_REDIRECT_URL=
CBE_ACCOUNT_NUMBER=
CBE_ACCOUNT_NAME=
CBE_BANK_BRANCH=
UPLOAD_DIR=./db/uploads
UPLOAD_MAX_BYTES=10485760
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
RESEND_API_KEY=
RESEND_FROM=
CORS_ORIGINS=
SENTRY_DSN=
REDIS_URL=
# SEC-03: optional dedicated key for field-level encryption (crypto-field.ts).
# Falls back to AUTH_SECRET if unset, so existing deployments keep working.
FIELD_ENCRYPTION_KEY=
# SEC-12: comma-separated trusted proxy IP/CIDR list. Empty = trust no
# proxies (use the socket peer as the client IP).
TRUSTED_PROXIES=
LOG_LEVEL=info
SCHEDULER_DISABLED=
# Set to 1 to bypass rate limiting entirely. Intended for e2e tests and local
# development only — never enable in production.
RATE_LIMIT_DISABLED=
SEED_ALLOW_PRODUCTION=
SEED_ADMIN_PASSWORD=
SEED_RIDER_PASSWORD=
SEED_CONTRACTOR_PASSWORD=
EXPO_PUBLIC_API_BASE=
EXPO_PUBLIC_API_ALLOW_HTTP=

# Resend webhook signature verification secret (required for /webhooks/resend/email-status)
RESEND_WEBHOOK_SECRET=
