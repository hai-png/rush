{
  "name": "@addis/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./src/app": "./src/app.ts",
    "./modules/*": "./modules/*",
    "./src/middleware/*": "./src/middleware/*",
    "./infra/*": "./infra/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "build": "tsc",
    "openapi:gen": "tsx scripts/gen-openapi.ts"
  },
  "dependencies": {
    "@addis/db": "workspace:*",
    "@addis/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/zod-openapi": "^0.18.4",
    "@paralleldrive/cuid2": "^2.2.2",
    "@upstash/redis": "^1.34.3",
    "archiver": "^7.0.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.4",
    "file-type": "^19.6.0",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "otplib": "^12.0.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/archiver": "^6.0.3",
    "@types/pino": "^7.0.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
