{
  "name": "@addis/sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.d.ts",
      "default": "./src/schema.d.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../api/openapi.json -o src/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": { "openapi-fetch": "^0.13.0" },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.7.0"
  }
}
